{
  "name": "palvelutarjotin-ui",
  "version": "2.18.0",
  "private": true,
  "engines": {
    "node": "^24"
  },
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "clean": "rimraf --no-glob ./.next ./out ./coverage ./tsconfig.tsbuildinfo",
    "prepare": "husky",
    "postinstall": "node scripts/fix-hds-core-cookie-consent.js",
    "dev": "next dev",
    "build": "next build",
    "build-fast": "cross-env NEXTJS_IGNORE_TYPECHECK=1 NEXTJS_DISABLE_SENTRY=1 NEXTJS_SENTRY_UPLOAD_DRY_RUN=1 next build",
    "start": "next start",
    "lint": "eslint src",
    "codegen": "cross-env DOTENV_CONFIG_PATH=\"./.env\" graphql-codegen -r dotenv/config --config codegen.yml",
    "format:code": "eslint src --fix",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "test": "cross-env SASS_PATH=./src/assets/styles jest --watch",
    "test:changed": "jest -o",
    "test:coverage": "jest --watchAll=false --coverage",
    "test:staged": "cross-env SASS_PATH=./src/assets/styles jest --findRelatedTests --passWithNoTests",
    "ci": "jest --verbose --coverage --runInBand",
    "codegen:browser": "playwright codegen",
    "test:browser": "playwright test",
    "test:browser:ci": "yarn test:browser"
  },
  "//": {
    "Why are packages in resolutions?": {
      "lodash": [
        "To fix GHSA-f23m-r3pf-42rh and GHSA-r5fr-rjxr-66jc",
        "Pinning lodash to >=4.18.1 fixes prototype pollution vulnerabilities",
        "NOTE: This can be removed when all transitive dependencies use patched lodash versions"
      ],
      "minimatch": [
        "To fix ReDoS vulnerability in transitive minimatch v3 and v9",
        "NOTE: This can be removed when all dependencies require patched versions"
      ],
      "immutable": [
        "To fix Prototype Pollution vulnerability in transitive immutable v3 and v5",
        "NOTE: This can be removed when all dependencies require patched versions"
      ],
      "isomorphic-dompurify": [
        "Pin to the last 2.x release before jsdom 27 while Turbopack resolves jsdom browser assets under /ROOT",
        "NOTE: This can be removed once Turbopack or upstream package compatibility is fixed"
      ],
      "tmp": [
        "tmp allows arbitrary temporary file/directory write via symbolic link in versions <0.2.4",
        "Pinning to >=0.2.4 via @graphql-codegen/cli > inquirer > external-editor > tmp",
        "See https://www.npmjs.com/advisories/1109537",
        "NOTE: This can be removed when @graphql-codegen/cli no longer resolves vulnerable tmp versions"
      ]
    }
  },
  "resolutions": {
    "isomorphic-dompurify": "2.26.0",
    "lodash": "^4.18.1",
    "**/@typescript-eslint/typescript-estree/minimatch": "^9.0.7",
    "**/@ardatan/relay-compiler/immutable": "^3.8.3",
    "tmp": ">=0.2.4",
    "hds-core": "file:.yalc/hds-core",
    "hds-design-tokens": "file:.yalc/hds-design-tokens",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "dependencies": {
    "@apollo/client": "^3.13.5",
    "@city-of-helsinki/react-helsinki-headless-cms": "3.0.0",
    "@date-fns/tz": "^1.2.0",
    "@jonkoops/matomo-tracker-react": "^0.7.0",
    "@sentry/nextjs": "^10.37.0",
    "axios": "^1.15.0",
    "classnames": "^2.5.1",
    "copy-to-clipboard": "^3.3.3",
    "cross-fetch": "^4.1.0",
    "date-fns": "^4.1.0",
    "deepmerge": "^4.3.1",
    "doctoc": "^2.2.1",
    "file-saver": "^2.0.5",
    "formik": "^2.4.6",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6",
    "hds-react": "file:.yalc/hds-react",
    "i18next": "^24.2.3",
    "ics": "^3.8.1",
    "lodash": "^4.18.1",
    "next": "16.2.3",
    "next-i18next": "^15.4.3",
    "picomatch": "^2.3.2",
    "react": "19.2.5",
    "react-content-loader": "^7.0.2",
    "react-dom": "19.2.5",
    "react-i18next": "^15.7.4",
    "react-table": "^7.8.0",
    "react-toastify": "^11.0.5",
    "react-use": "^17.6.0",
    "use-deep-compare-effect": "^1.8.1",
    "uuid": "^11.1.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@faker-js/faker": "^9.6.0",
    "@graphql-codegen/cli": "^5.0.5",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-operations": "^4.6.0",
    "@graphql-codegen/typescript-react-apollo": "^4.3.2",
    "@next/eslint-plugin-next": "16.2.3",
    "@playwright/test": "^1.56.1",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@swc/core": "^1.11.15",
    "@swc/jest": "^0.2.37",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.14",
    "@types/jest-axe": "^3.5.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.17.29",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-table": "^7.7.20",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-date-mock": "^1.0.10",
    "jest-fixed-jsdom": "^0.0.9",
    "jest-localstorage-mock": "^2.4.26",
    "lint-staged": "^16.4.0",
    "msw": "^2.7.3",
    "prettier": "^3.5.3",
    "sass": "^1.98.0",
    "stylelint": "^16.17.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-scss": "^6.11.1",
    "typescript": "^5.8.2",
    "waait": "^1.0.5"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write",
      "yarn test:staged"
    ],
    "src/**/*.scss": [
      "stylelint --fix"
    ]
  }
}
